---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Navigation -->
	<header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-slate-200/50 transition-all duration-300">
		<div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
			<!-- Logo -->
			<a href="#hero" class="flex items-center gap-2 group">
				<span class="text-xl font-display font-extrabold tracking-tight text-slate-900">
					Mateo Lara<span class="text-teal-600 group-hover:text-teal-500 transition-colors">.</span>
				</span>
			</a>

			<!-- Desktop Nav -->
			<nav class="hidden md:flex items-center gap-8">
				<a href="#enfoque" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Metodología</a>
				<a href="#casos" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Casos de Estudio</a>
				<a href="#stack" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Capacidades</a>
			</nav>

			<!-- Action CTA -->
			<div class="hidden md:flex items-center gap-4">
				<a 
					id="nav-cta"
					href="https://cal.com/mateo-lara-reguera/llamada-de-descubrimiento" 
					target="_blank" 
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center rounded-xl bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-xs hover:bg-teal-500 hover:shadow-[0_0_15px_rgba(20,184,166,0.2)] focus-visible:outline-teal-600 transition-all duration-200 hover:-translate-y-0.5"
				>
					Diagnóstico 100% gratis
				</a>
			</div>

			<!-- Mobile menu button -->
			<button 
				id="menu-btn" 
				type="button" 
				class="inline-flex items-center justify-center rounded-xl p-2 text-slate-650 hover:bg-slate-100 hover:text-slate-900 focus:outline-none md:hidden" 
				aria-controls="mobile-menu" 
				aria-expanded="false"
			>
				<span class="sr-only">Abrir menú principal</span>
				<!-- Menu open icon -->
				<svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
				</svg>
				<!-- Menu close icon -->
				<svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</div>

		<!-- Mobile menu -->
		<div class="hidden md:hidden border-b border-slate-200 bg-white" id="mobile-menu">
			<div class="space-y-1 px-4 pb-4 pt-2">
				<a href="#enfoque" class="block rounded-lg px-3 py-2 text-base font-semibold text-slate-700 hover:bg-slate-100 hover:text-slate-900">Metodología</a>
				<a href="#casos" class="block rounded-lg px-3 py-2 text-base font-semibold text-slate-700 hover:bg-slate-100 hover:text-slate-900">Casos de Estudio</a>
				<a href="#stack" class="block rounded-lg px-3 py-2 text-base font-semibold text-slate-700 hover:bg-slate-100 hover:text-slate-900">Capacidades</a>
				<a 
					id="mobile-nav-cta"
					href="https://cal.com/mateo-lara-reguera/llamada-de-descubrimiento" 
					target="_blank" 
					rel="noopener noreferrer"
					class="mt-2 block w-full rounded-xl bg-teal-600 px-4 py-2.5 text-center text-base font-semibold text-white shadow-xs hover:bg-teal-500"
				>
					Reservar diagnóstico gratis
				</a>
			</div>
		</div>
	</header>

	<main class="flex-grow">
		<!-- Section 1: Hero -->
		<section id="hero" class="relative overflow-hidden pt-10 pb-16 lg:pt-14 lg:pb-24 bg-slate-50">
			<!-- Subtle ambient glowing backgrounds -->
			<div class="absolute -top-40 -right-40 -z-10 h-[400px] w-[400px] rounded-full bg-teal-500/5 blur-3xl"></div>
			<div class="absolute -bottom-40 -left-40 -z-10 h-[400px] w-[400px] rounded-full bg-cyan-500/5 blur-3xl"></div>

			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					
					<!-- Left Column: Copy & CTAs -->
					<div class="text-left space-y-8">
						<h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold tracking-tight text-slate-900 leading-[1.1]">
							Recupera tiempo. <span class="bg-gradient-to-r from-teal-600 via-cyan-600 to-emerald-600 bg-clip-text text-transparent">Automatiza lo que frena tu negocio.</span>
						</h1>
						
						<p class="text-lg sm:text-xl text-slate-650 max-w-xl font-normal leading-relaxed">
							Diseño e implemento flujos autónomos en Python, n8n y Agentes de IA. Libera a tu equipo de la carga operativa con sistemas estables.
						</p>

						<!-- Bullet points of key advantages -->
						<ul class="space-y-3.5 text-slate-650 text-sm sm:text-base">
							<li class="flex items-center gap-3">
								<svg class="h-5 w-5 text-teal-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
								<span><strong>Eficiencia operativa:</strong> +100 horas recuperadas mensualmente.</span>
							</li>
							<li class="flex items-center gap-3">
								<svg class="h-5 w-5 text-teal-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
								<span><strong>Integración de sistemas:</strong> Conexión fluida de CRMs y APIs.</span>
							</li>
							<li class="flex items-center gap-3">
								<svg class="h-5 w-5 text-teal-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
								<span><strong>Seguridad y robustez:</strong> Código limpio en Python y despliegues estables.</span>
							</li>
						</ul>

						<!-- Hero CTAs -->
						<div class="flex flex-col sm:flex-row gap-4 pt-4">
							<a 
								id="hero-primary-cta"
								href="https://cal.com/mateo-lara-reguera/llamada-de-descubrimiento" 
								target="_blank" 
								rel="noopener noreferrer"
								class="inline-flex items-center justify-center rounded-xl bg-teal-600 px-6 py-3.5 text-base font-semibold text-white shadow-xs hover:bg-teal-500 hover:shadow-[0_0_15px_rgba(20,184,166,0.2)] transition-all duration-200 hover:-translate-y-0.5"
							>
								Reservar diagnóstico gratis
								<svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
								</svg>
							</a>
							<a 
								id="hero-secondary-cta"
								href="#casos" 
								class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-6 py-3.5 text-base font-semibold text-slate-700 shadow-xs hover:bg-slate-50 hover:border-slate-350 transition-all duration-200"
							>
								Casos de estudio
							</a>
						</div>
					</div>

					<!-- Right Column: Profile Image / Visual integrated seamlessly with background -->
					<div class="flex justify-center lg:justify-end w-full">
						<div class="w-full max-w-[520px] relative">
							<!-- Image itself (no rounded-2xl, no border, no shadow, no aspect-square constraint) -->
							<img 
								src="/images/mateo-hero.webp" 
								alt="Mateo Lara Reguera - Consultor de Automatizaciones e IA" 
								class="w-full h-auto object-cover relative"
								width="520"
								height="520"
								loading="eager"
							/>
							<!-- Seamless left-to-right gradient overlay to blend the image with the background -->
							<div class="hidden lg:block absolute inset-0 bg-gradient-to-r from-slate-50 via-slate-50/50 via-20% to-transparent to-30% pointer-events-none"></div>
							<!-- Additional bottom-to-top gradient overlay to fade the bottom of the photo -->
							<div class="hidden lg:block absolute inset-0 bg-gradient-to-t from-slate-50 via-slate-50/20 via-10% to-transparent to-20% pointer-events-none"></div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- Section 2: El Enfoque -->
		<section id="enfoque" class="bg-slate-950 text-slate-100 py-20 sm:py-24 border-y border-slate-900 relative overflow-hidden">
			<!-- Subtle dark ambient glow -->
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 h-[500px] w-[500px] rounded-full bg-teal-950/10 blur-[100px]"></div>

			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				
				<!-- Section Header -->
				<div class="max-w-3xl text-left mb-16 space-y-4">
					<h2 class="text-xs font-bold uppercase tracking-widest text-teal-400">Metodología de Trabajo</h2>
					<p class="text-3xl sm:text-4xl font-display font-extrabold tracking-tight text-white">
						El Enfoque: De la ineficiencia a la autonomía operativa
					</p>
					<p class="text-lg text-slate-300 font-normal">
						No implemento herramientas tecnológicas para seguir tendencias. Trabajo de forma estructurada para diseñar arquitecturas de automatización robustas, conectando sistemas heredados con orquestadores avanzados y agentes inteligentes.
					</p>
				</div>

				<!-- Process Steps -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
					<!-- Step 1 -->
					<div class="bg-slate-900/40 backdrop-blur-sm rounded-xl p-8 border border-slate-800 shadow-lg relative group hover:border-teal-500/55 hover:bg-slate-900/70 transition-all duration-300">
						<div class="absolute -top-3 -left-3 h-8 w-8 rounded-lg bg-slate-950 border border-teal-500/30 flex items-center justify-center text-xs font-mono font-bold text-teal-400">01</div>
						<h3 class="text-lg font-bold text-white mb-3 font-display mt-2">Diagnóstico</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Reunión inicial 100% gratuita para mapear tus cuellos de botella y definir qué procesos tienen más impacto si se automatizan.
						</p>
						<div class="mt-4 pt-4 border-t border-slate-800/85 flex items-center justify-between text-xs font-mono text-slate-500">
							<span>Precio</span>
							<span class="text-teal-400 font-bold">100% Gratis</span>
						</div>
					</div>

					<!-- Step 2 -->
					<div class="bg-slate-900/40 backdrop-blur-sm rounded-xl p-8 border border-slate-800 shadow-lg relative group hover:border-teal-500/55 hover:bg-slate-900/70 transition-all duration-300">
						<div class="absolute -top-3 -left-3 h-8 w-8 rounded-lg bg-slate-950 border border-teal-500/30 flex items-center justify-center text-xs font-mono font-bold text-teal-400">02</div>
						<h3 class="text-lg font-bold text-white mb-3 font-display mt-2">Propuesta modular</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Proyecto adaptado a tu presupuesto, planificado por módulos para que mantengas siempre el control total del alcance y del coste.
						</p>
						<div class="mt-4 pt-4 border-t border-slate-800/85 flex items-center justify-between text-xs font-mono text-slate-500">
							<span>Planificación</span>
							<span class="text-teal-400">Por entregables</span>
						</div>
					</div>

					<!-- Step 3 -->
					<div class="bg-slate-900/40 backdrop-blur-sm rounded-xl p-8 border border-slate-800 shadow-lg relative group hover:border-teal-500/55 hover:bg-slate-900/70 transition-all duration-300">
						<div class="absolute -top-3 -left-3 h-8 w-8 rounded-lg bg-slate-950 border border-teal-500/30 flex items-center justify-center text-xs font-mono font-bold text-teal-400">03</div>
						<h3 class="text-lg font-bold text-white mb-3 font-display mt-2">Desarrollo con feedback</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Desarrollo transparente y ágil. Puedes seguir los avances y pruebas en tiempo real o recibir el resultado final según prefieras.
						</p>
						<div class="mt-4 pt-4 border-t border-slate-800/85 flex items-center justify-between text-xs font-mono text-slate-500">
							<span>Seguimiento</span>
							<span class="text-teal-400">En tiempo real</span>
						</div>
					</div>

					<!-- Step 4 -->
					<div class="bg-slate-900/40 backdrop-blur-sm rounded-xl p-8 border border-slate-800 shadow-lg relative group hover:border-teal-500/55 hover:bg-slate-900/70 transition-all duration-300">
						<div class="absolute -top-3 -left-3 h-8 w-8 rounded-lg bg-slate-950 border border-teal-500/30 flex items-center justify-center text-xs font-mono font-bold text-teal-400">04</div>
						<h3 class="text-lg font-bold text-white mb-3 font-display mt-2">Entrega y formación</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Instalación final en tus entornos, pruebas exhaustivas y formación detallada al equipo que vaya a utilizar las herramientas.
						</p>
						<div class="mt-4 pt-4 border-t border-slate-800/85 flex items-center justify-between text-xs font-mono text-slate-500">
							<span>Acompañamiento</span>
							<span class="text-teal-400">Puesta en marcha</span>
						</div>
					</div>
				</div>

			</div>
		</section>

		<!-- Section 3: Casos de Uso Concretos -->
		<section id="casos" class="py-20 sm:py-24 bg-white border-b border-slate-200/50">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				
				<!-- Section Header -->
				<div class="max-w-3xl text-left mb-16 space-y-4">
					<h2 class="text-xs font-bold uppercase tracking-widest text-teal-600">Casos de Éxito</h2>
					<p class="text-3xl sm:text-4xl font-display font-extrabold text-slate-900 tracking-tight">
						Soluciones y casos de estudio
					</p>
					<p class="text-lg text-slate-655 font-normal">
						Ejemplos reales de cómo transformamos operaciones tradicionales en sistemas automatizados de alto rendimiento.
					</p>
				</div>

				<!-- Two Column Success Cases Grid -->
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
					
					<!-- Caso 1: Clínica de Psicología Rodríguez Vidondo -->
					<div class="bg-slate-50/50 rounded-2xl border border-slate-200 shadow-xs p-6 sm:p-8 flex flex-col justify-between group hover:border-teal-500/30 hover:shadow-md transition-all duration-300 relative overflow-hidden">
						<!-- Subtle gradient backdrop -->
						<div class="absolute top-0 right-0 w-64 h-64 bg-teal-500/5 rounded-full blur-3xl -z-10 -mr-20 -mt-20"></div>
						
						<div class="space-y-5">
							<div class="flex items-center justify-between">
								<span class="text-xs font-mono font-bold uppercase tracking-wider text-teal-600 bg-teal-555/10 px-2.5 py-1 rounded-md">Salud & SEO Local</span>
							</div>
							
							<h3 class="text-xl sm:text-2xl font-display font-extrabold text-slate-900 tracking-tight">
								Clínica de Psicología Rodríguez Vidondo
							</h3>
							
							<p class="text-sm text-slate-655 leading-relaxed">
								Automatización completa del ciclo de captación y retención de pacientes. Sistema de solicitud automática de reseñas en Google Business Profile en el momento de mayor satisfacción, potenciando el SEO local y la prueba social. Panel de NPS automático con visualización en Google Data Studio. En fase de cierre: base de datos centralizada con estadísticas clave de la clínica.
							</p>

							<!-- Visual element: Star feedback request simulation -->
							<div class="pt-2 flex items-center gap-3">
								<div class="flex text-amber-400">
									<svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
									<svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
									<svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
									<svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
									<svg class="w-5 h-5 fill-current text-slate-200" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
								</div>
								<span class="text-xs font-semibold text-slate-500 font-mono">Feedback ➔ Reseña GBP (Automatizado)</span>
							</div>
						</div>
						
						<div class="mt-8 pt-6 border-t border-slate-100 flex flex-wrap gap-8 items-center">
							<div>
								<p class="text-2xl font-display font-extrabold text-teal-600">+180%</p>
								<p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider">Reseñas en Google</p>
							</div>
							<div>
								<p class="text-2xl font-display font-extrabold text-slate-900">96%</p>
								<p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider">NPS medio registrado</p>
							</div>
						</div>
					</div>

					<!-- Caso 2: Empresa del sector turístico (DataGrowth) -->
					<div class="bg-slate-50/50 rounded-2xl border border-slate-200 shadow-xs p-6 sm:p-8 flex flex-col justify-between group hover:border-teal-500/30 hover:shadow-md transition-all duration-300 relative overflow-hidden">
						<!-- Subtle gradient backdrop -->
						<div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/5 rounded-full blur-3xl -z-10 -mr-20 -mt-20"></div>
						
						<div class="space-y-5">
							<div class="flex items-center justify-between">
								<span class="text-xs font-mono font-bold uppercase tracking-wider text-teal-600 bg-teal-550/10 px-2.5 py-1 rounded-md">Integraciones & ERP</span>
							</div>
							
							<h3 class="text-xl sm:text-2xl font-display font-extrabold text-slate-900 tracking-tight">
								Empresa Turística (DataGrowth)
							</h3>
							
							<p class="text-sm text-slate-655 leading-relaxed">
								Integración de TuriTop (reservas) con Holded (ERP) mediante n8n. Cada evento vendido genera automáticamente una factura legalmente vinculada. Registro centralizado en Supabase para control de flujos complejos y excepciones de la API de Holded. Resultado: eliminación del cuello de botella financiero y capacidad para gestionar picos de demanda sin carga administrativa adicional.
							</p>

							<!-- Visual integration flow simulator -->
							<div class="pt-2 flex items-center gap-1.5 text-xs font-mono text-slate-500">
								<span class="px-2 py-0.5 bg-slate-100 rounded border border-slate-200">TuriTop</span>
